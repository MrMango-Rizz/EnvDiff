# A deliberately BROKEN .env to demonstrate what envdiff catches.

NODE_ENV=production

# SERVER_PORT is MISSING entirely -> error (required)

# DATABASE_URL has a bad value -> type error (not a url)
DATABASE_URL=localhost5432

# ADMIN_EMAIL is malformed -> type error
ADMIN_EMAIL=admin(at)example.com

# DEBUG has an invalid boolean -> type error
DEBUG=sometimes

# MAX_RETRIES is empty -> empty warning
MAX_RETRIES=

# A real-looking AWS key committed here -> secret warning
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE

# STRIPE key left as placeholder -> fine
STRIPE_SECRET_KEY=your-stripe-key-here

# JWT_SECRET now holds a real high-entropy value -> secret warning
JWT_SECRET=aB3xK9pQ7mR2vN5wL8zT1yU4hG6dF0sJ

# Duplicate definition -> duplicate warning
NODE_ENV=staging

# Extra key not in example -> extra warning
LEGACY_FLAG=1
