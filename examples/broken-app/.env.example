# Example environment for the demo "broken-app".
# Copy to .env and fill in real values.

# Core server config
NODE_ENV=            # type: string
SERVER_PORT=         # type: port required
DATABASE_URL=        # type: url required
ADMIN_EMAIL=         # type: email

# Feature flags
DEBUG=               # type: boolean optional
MAX_RETRIES=         # type: integer

# Third-party credentials (placeholders only!)
STRIPE_SECRET_KEY=your-stripe-key-here
JWT_SECRET=changeme
